# Server
PORT=4000
NODE_ENV=development

# ─── Database (Supabase) — pg driver, migrations only ────────────────────────
# Supabase Dashboard → Settings → Database → URI tab → Session mode (port 5432)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Supabase JS client — all application code ───────────────────────────────
# Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-service-role-key   # Service role key — bypasses RLS. NEVER expose client-side.

# ─── TripJack — same key for flights AND hotels ──────────────────────────────
TRIPJACK_API_KEY=
TRIPJACK_BASE_URL=https://apitest.tripjack.com          # OMS + FMS (flights, booking, hotel booking)
TRIPJACK_HOTEL_BASE_URL=https://apitest-hms.tripjack.com  # HMS (hotel search, pricing, review)

# ─── Cron ────────────────────────────────────────────────────────────────────
CRON_SCHEDULE=0 2 * * *               # 2am daily
MAX_CONCURRENT_FLIGHT_WORKERS=10
MAX_CONCURRENT_HOTEL_WORKERS=5

# ─── Business config ─────────────────────────────────────────────────────────
REFERENCE_NIGHTS=5                    # cron always uses return = departure + 5 days
CHILD_FARE_RATIO=0.75                 # child flight price = adult × 0.75
TOP_N_FLIGHTS=3                       # cache 3 cheapest airlines per route-date
CACHE_DAYS_TIER1=30                   # refresh days 1-30 daily
CACHE_DAYS_TIER2=90                   # refresh days 31-90 every 3 days
MAX_OCCUPANCY_PER_ROOM=3              # 2 adults + 1 child max per room
