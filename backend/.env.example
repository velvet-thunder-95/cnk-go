# Server
PORT=4000
NODE_ENV=development

# ─── Database (Supabase) ───────────────────────────────────────────────────────
# Supabase Dashboard → Settings → Database → URI tab → Session mode (port 5432)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Tripjack (Flights) — fill in when API access is granted ──────────────────
TRIPJACK_API_KEY=
TRIPJACK_BASE_URL=https://apiplayground.tripjack.com

# ─── Booking.com (Hotels) — fill in when API access is granted ───────────────
BOOKING_COM_API_KEY=
BOOKING_COM_AFFILIATE_ID=
BOOKING_COM_BASE_URL=https://demandapi-sandbox.booking.com/3.2
